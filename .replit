modules = ["nodejs-20", "php-8.2", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
APP_DEBUG = "true"
APP_ENV = "local"
APP_KEY = "base64:cqXbqdk3G5N82Nam7SgWX2fhMnHgfB53YfjHH9H17XI="
APP_NAME = "ShopWave"
APP_URL = "http://localhost"
CACHE_STORE = "file"
DB_CONNECTION = "pgsql"
DB_DATABASE = "neondb"
FILESYSTEM_DISK = "local"
MAIL_FROM_ADDRESS = "noreply@shopwave.com"
MAIL_FROM_NAME = "ShopWave"
MAIL_MAILER = "log"
QUEUE_CONNECTION = "sync"
SESSION_DRIVER = "file"
SESSION_LIFETIME = "120"
DB_HOST = "ep-winter-band-avjlxf1r-pooler.c-11.us-east-1.aws.neon.tech"
DB_PORT = "5432"
